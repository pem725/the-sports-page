    {"no": 14, "id": "measurement",                     "title": "Measurement: Building a Metric",         "theme": "measurement",     "status": "published", "primer": "concepts/measurement-building-a-metric.html",   "book_chapters": ["10-reliability.qmd", "11-validity.qmd"], "issues": ["097-acceleration-second-derivative.html", "099-clark-three-dimension.html"],
      "summary": "A metric is built, not found: a number stands in for a trait you can't touch. Then the only two questions that matter — reliability (does it agree with itself?) and validity (does it measure what you claim?). Anchor issue: the 'acceleration' metric and its window problem."},

    {"no": 15, "id": "all-models-are-wrong",           "title": "All Models Are Wrong (and Overfitting)", "theme": "modeling",        "status": "ready",     "primer": null,                                            "book_chapters": ["12-GLMcovariance.qmd", "14-bivariateregression.qmd"], "issues": [],
      "summary": "Box: all models are wrong, some useful. A line through every data point forecasts nothing (overfit); a useful model is honest about its error and ignores the outliers we fixate on. Anchor candidates: pre-season simulations, prediction-framework issues, 'the prior isn't a promise.'"},

    {"no": 16, "id": "believe-data-model-theory",      "title": "Do We Believe the Data, the Model, or the Theory?", "theme": "epistemics", "status": "ready", "primer": null,                                            "book_chapters": [], "issues": [],
